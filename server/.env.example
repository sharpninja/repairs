# Google OAuth Web client ID (the audience the ID token must match).
# Create at https://console.cloud.google.com/apis/credentials → OAuth client ID → Web.
# Add your app origin (e.g. https://sharpninja.github.io) to "Authorized JavaScript origins".
# The app now uses the top-level REDIRECT sign-in (works under tracking prevention /
# installed PWAs), so ALSO add the callback below to "Authorized redirect URIs":
#   https://sharpninja.ngrok.app/auth/google/callback   (exact match to the public backend origin)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Redirect sign-in return target: the in-scope PWA URL the backend 303s back to after
# verifying the Google ID token (must be inside the app's manifest scope). The one-time
# handoff code rides in the URL fragment. Defaults to the published GitHub Pages app.
APP_ORIGIN=https://sharpninja.github.io/repairs/
# HANDOFF_TTL_MS=120000   # how long a single-use sign-in handoff code stays valid (default 2 min)

# Sign in with Apple: the Services ID configured for Sign in with Apple (the
# audience the Apple identity token must match). Distinct from the iOS app's
# Bundle ID. Sign in with Apple also needs, on the Apple Developer portal, a
# registered Services ID + a Sign in with Apple key + return URLs (account
# setup the server cannot automate). Leave blank until set up; the client
# defaults to Google (provider "google") for backward compatibility.
APPLE_CLIENT_ID=

# GitHub credential the server uses to open + moderate PRs.
#
# RECOMMENDED: a GitHub App (least-privilege, auto-refreshing). Create an App with
# repo permissions Contents:RW, Pull requests:RW, Issues:RW, Metadata:R, install it
# on the repo, then set the three GITHUB_APP_* vars below. `./setup.sh` (or
# `npm run mint-token`) fills them in and mints a scoped GITHUB_TOKEN for you.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=            # PEM with newlines as \n (single line)
GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/app.pem   # alternative to the inline key

# FALLBACK: a fine-grained PAT scoped to the repo with Contents + Pull requests +
# Issues: Read/Write. Used only if the GITHUB_APP_* vars above are unset. When the
# App vars are set, the server auto-refreshes and this is just a convenience/fallback.
GITHUB_TOKEN=

# Data repo + published branch (defaults shown). Submissions open PRs against the
# "approved" branch of the DATA repo (separate from the app code repo). The App/PAT
# credential must have access to this repo.
GITHUB_OWNER=sharpninja
GITHUB_REPO=repairs-data
GITHUB_BASE=approved
MARKETPLACE_PATH=marketplace.json

# CORS: the exact origin of the deployed PWA (or * to allow any).
ALLOWED_ORIGIN=https://sharpninja.github.io

PORT=8788   # host/container port for the submit service (do not use 8080)

# ---- Amazon affiliate ----
# Amazon Associate tag appended to shopping links. Served to the app via the
# unauthenticated GetAppConfig RPC on startup. Leave blank for plain (untagged) searches.
AMAZON_ASSOCIATE_TAG=

# ---- Direct operator guide submission ----
# Server-side scripts may submit guides directly with:
#   Authorization: Bearer <DIRECT_SUBMIT_BEARER_TOKEN>
# This bypass is only accepted by SubmitRepair, never by review submission, and must not
# be placed in browser/PWA settings or checked into git. Generate with:
#   openssl rand -hex 32
DIRECT_SUBMIT_BEARER_TOKEN=
DIRECT_SUBMIT_AUTHOR_EMAIL=
DIRECT_SUBMIT_AUTHOR_NAME=

# ---- Public tunnel (ngrok) ----
# Exposes the submit service on a public HTTPS URL so the deployed app or a phone
# can reach it. Free token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ---- Claude moderation (Claude Code CLI, SUBSCRIPTION auth — no API key) ----
# Generate on a machine where you're logged into Claude: `claude setup-token`
# (needs a Claude Pro/Max subscription). Paste the long-lived token here.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxx
# Optional overrides:
# CLAUDE_CLI=claude            # binary name/path
# CLAUDE_ARGS=                 # extra flags passed to `claude -p`
# CLAUDE_TIMEOUT_MS=120000
# MODERATE_ON_SUBMIT=true      # moderate inline right after the PR is opened
# SUBMISSION_LABEL=app-submission
# MONITOR_INTERVAL_MS=60000    # poll cadence for the standalone monitor
# Approved PRs are auto-merged; merge failures leave the PR open with a failure comment.
# AUTO_CLOSE_REJECT=false      # auto-close PRs Claude rejects (else just labels)

# ---- Sessions, trust & rate limiting (persistent storage) ----
# Persisted under a mounted volume (docker-compose provides one at /app/data).
# TRUST_STORE=/app/data/trust.json
# SESSION_STORE=/app/data/sessions.json
# BANS_STORE=/app/data/bans.json      # append-only ban audit log; review with `npm run bans`
# CLIENT_ERRORS_STORE=/app/data/client-errors.jsonl  # deidentified client error reports (JSONL, capped ~5MB)
# MODERATION_LOG_STORE=/app/data/moderation.jsonl     # moderation verdict log (JSONL) shown in the admin dashboard

# ---- Admin dashboard ----
# Token that gates GET /admin (moderation status/logs + error logs + bans).
# Unset = the /admin route is disabled (404). Generate: openssl rand -hex 32
ADMIN_TOKEN=
# SESSION_TTL_MS=86400000      # session lifetime (24h); rotated on app startup
# SUBMIT_RATE_MS=60000         # min gap between a user's submissions (1/min)
# TRUST_BLOCK_AT=-4            # score at/below which a user is silently dropped
